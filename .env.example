# Use in-memory store for local dev (no AWS required)
USE_LOCAL_STORE=true

# AWS DynamoDB (production — provision with Terraform: npm run infra:deploy)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Table names (defaults match terraform/dynamodb.tf — override if project_name differs)
DYNAMODB_PRODUCTS_TABLE=recallnet-products
DYNAMODB_OWNERSHIP_TABLE=recallnet-ownership-events
DYNAMODB_RECALLS_TABLE=recallnet-recall-events
DYNAMODB_STATUS_TABLE=recallnet-user-recall-status

# Optional — S3 receipt uploads (created by Terraform when create_s3_receipts_bucket=true)
S3_RECEIPTS_BUCKET=

# Optional — days of CPSC history to preload when catalog is empty (default 90)
RECALL_SYNC_DAYS=90

# Public app URL (for share reports)
NEXT_PUBLIC_APP_URL=http://localhost:3001
